# =============================================================================
# Nafer Backend — Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# --- Production Core ---
# IMPORTANT: DATABASE_URL should point to your external Render Managed Postgres
DATABASE_URL=postgres://user:password@host.render.com:5432/dbname?sslmode=require

# --- Internal Monolith Services (Localhost) ---
REDIS_URL=localhost:6379
MINIO_ENDPOINT=localhost:9000
MEILI_URL=http://localhost:7700

# --- Secrets ---
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=24h
MEILI_MASTER_KEY=change_me_in_production
MINIO_ROOT_USER=nafer_storage_admin
MINIO_ROOT_PASSWORD=change_me_in_production
